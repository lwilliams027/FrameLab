# FrameLab Supabase configuration
#
# Copy this file to `.env.local` (which is gitignored) and fill in your
# project's values. The anon key is safe to commit if you ever need to —
# it's designed to be public and is what the browser uses to talk to
# Supabase. RLS policies in the database control what it can actually do.
#
# Get these from: Supabase dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOURPROJECTREF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PUT_YOUR_ANON_KEY_HERE
